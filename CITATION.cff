    family-names: "Yousef"
    orcid: "https://orcid.org/0009-0006-7409-9367"
    affiliation: "Department of Artificial Intelligence Engineering, AlSafwa University, Karbala, Iraq"
    email: kazimayemn@gmail.com
license: MIT
